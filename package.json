{
  "name": "devrolin-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "dev:prod": "npm run build && npm run start",
    "hocuspocus:dev": "ts-node --project tsconfig.server.json hocuspocus-server.ts",
    "hocuspocus:start": "cross-env NODE_ENV=production ts-node --project tsconfig.server.json hocuspocus-server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "lint": "next lint",
    "bootstrap:users": "node src/scripts/bootstrap-users.js",
    "bootstrap:users:all": "node src/scripts/bootstrap-users.js --all",
    "bootstrap:users:reset": "node src/scripts/bootstrap-users.js --reset --all",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@blocknote/core": "^0.15.0",
    "@blocknote/mantine": "^0.15.0",
    "@blocknote/react": "^0.15.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@hocuspocus/provider": "^2.13.0",
    "@hocuspocus/server": "^2.13.0",
    "@mantine/core": "^7.11.0",
    "@mantine/hooks": "^7.11.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cookie": "^0.6.0",
    "cookie-parser": "^1.4.6",
    "daisyui": "^4.12.10",
    "dayjs": "^1.11.12",
    "dotenv": "^17.4.1",
    "express": "^4.19.2",
    "framer-motion": "^11.3.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.400.0",
    "next": "^14.2.5",
    "next-pwa": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-image-crop": "^11.0.6",
    "react-intersection-observer": "^9.13.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "resend": "^3.5.0",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "yjs": "^13.6.18",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.3",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
